# Provider selection. If unset, it is auto-detected from whichever API key is
# present (Anthropic preferred). Set explicitly to force one.
# SENTRET_PROVIDER=anthropic   # anthropic | openai

# --- Anthropic (default provider) ---
ANTHROPIC_API_KEY=
SENTRET_MODEL=claude-fable-5
# Optional fallback model used when the primary model declines a request
# (Fable 5 safety classifiers can return stop_reason "refusal" on benign
# security-adjacent work; the conversation is replayed as-is on this model).
# Set empty to disable. Anthropic-only.
SENTRET_FALLBACK_MODEL=claude-opus-4-8

# --- OpenAI (or any OpenAI-compatible endpoint) ---
OPENAI_API_KEY=
# Set this to your exact model id; the default below is a placeholder.
OPENAI_MODEL=gpt-4.1
# For OpenRouter / local OpenAI-compatible servers, point at their base URL.
# (For Azure AI Foundry, use the Azure block below instead — not OPENAI_BASE_URL.)
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# --- Azure AI Foundry / Azure OpenAI (provider: azure) ---
# Resource endpoint (NOT the deployment URL), e.g. https://my-foundry.openai.azure.com
# Setting this auto-selects the azure provider unless ANTHROPIC_API_KEY is also set.
AZURE_OPENAI_ENDPOINT=
# The deployment name of your model (e.g. your GPT-5.5 deployment) — Azure routes by deployment.
AZURE_OPENAI_DEPLOYMENT=
# REST api-version your deployment requires. Set this to match Foundry; the default may be wrong.
AZURE_OPENAI_API_VERSION=2025-04-01-preview
# Auth: set a key, OR leave it empty to use Entra ID via DefaultAzureCredential (az login).
AZURE_OPENAI_API_KEY=
# Reasoning models (GPT-5.x) under an opaque deployment name: force reasoning_effort on.
# auto (infer from name) | always | never
SENTRET_REASONING=auto

# --- Shared run configuration ---
SENTRET_EFFORT=high
SENTRET_MAX_TOKENS=64000
SENTRET_MAX_ITERATIONS=40

# Azure (used via DefaultAzureCredential — run `az login` or supply a
# service principal through the standard AZURE_* environment variables).
# Never put client secrets in this file in real deployments.
SENTRET_LOG_ANALYTICS_ENDPOINT=https://api.loganalytics.azure.com
SENTRET_ARM_ENDPOINT=https://management.azure.com

# Output / audit
SENTRET_OUTPUT_DIR=./reports
SENTRET_AUDIT_LOG=./audit/queries.jsonl

# Web UI (npm run serve)
SENTRET_WEB_HOST=127.0.0.1
SENTRET_WEB_PORT=8787
